{
  "manifest_version": 3,
  "name": "MiniGuard",
  "version": "1.0",
  "description": "A minimal AdGuard-like extension",

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "MiniGuard"
  },

  "web_accessible_resources": [
    {
      "resources": ["cosmetic_rules.json"],
      "matches": ["<all_urls>"]
    }
  ],

  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage",
    "tabs"
  ],

  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "miniguard_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
